{
  "clock": {
    "format": "箚꺊 <span size='11pt'>{:%H:%M}</span>",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "format": {
        "months": "<span color='#89b4fa'><b>{}</b></span>",
        "weekdays": "<span color='#a6e3a1'>{}</span>",
        "today": "<span color='#f38ba8'><b><u>{}</u></b></span>"
      }
    }
  }
}
