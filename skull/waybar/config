{
    "layer": "top",
    "position": "top",
    "height": 30,
    "margin-left": 8,
    "margin-right": 8,
    "margin-top": 4,
    "spacing": 6,
    "modules-left": [
        "custom/launcher",
        "hyprland/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "cpu",
        "memory",
        "wireplumber",
        "network",
        "battery",
        "custom/power"
    ],
    "custom/launcher": {
        "format": "ΎΝΥ",
        "tooltip": false,
        "on-click": "/home/kauadev/TEMAS/skull/waybar/launcher.sh",
        "on-click-right": "wofi --show run"
    },
    "hyprland/workspaces": {
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "≤░Ψθ",
            "2": "ΎΤΚ",
            "3": "≤░Ι╣",
            "4": "≤░ΚΜ",
            "5": "ΎΑΒ",
            "6": "≤░ΤΥ",
            "7": "≤░φ╗",
            "8": "≤░ΟΒ",
            "9": "≤░Ιχ",
            "10": "≤░Λλ"
        },
        "on-scroll-up": "hyprctl dispatch workspace e+1 1>/dev/null",
        "on-scroll-down": "hyprctl dispatch workspace e-1 1>/dev/null",
        "sort-by-number": true,
        "active-only": false
    },
    "clock": {
        "format": "{:%H:%M  ΎΒλ  %A, %d %b}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "today-format": "<b>{}</b>",
        "interval": 30
    },
    "cpu": {
        "interval": 2,
        "format": "ΎΜδ {usage}%",
        "max-length": 10,
        "min-length": 8
    },
    "memory": {
        "interval": 30,
        "format": "ΎΔΚ {used:0.1f}G"
    },
    "wireplumber": {
        "format": "{icon} {volume}%",
        "format-muted": "ΎΑο",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΑξ",
            "headset": "ΎΑξ",
            "phone": "ΎΑξ",
            "portable": "ΎΑξ",
            "car": "ΎΑξ",
            "default": [
                "ΎΑπ",
                "ΎΑπ",
                "ΎΑρ"
            ]
        },
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "scroll-step": 5
    },
    "network": {
        "format-wifi": "ΎΘτ",
        "format-ethernet": "Ύδ┐",
        "format-disconnected": "ΎΒ▓",
        "tooltip-format": "{essid} ({signalStrength}%)",
        "interval": 10
    },
    "battery": {
        "interval": 5,
        "states": {
            "good": 90,
            "warning": 25,
            "critical": 10
        },
        "format": "{icon}",
        "format-charging": "ΎΘο",
        "format-plugged": "ΎΘο",
        "format-icons": [
            "ΎΚΕ",
            "ΎΚΔ",
            "ΎΚΓ",
            "ΎΚΒ",
            "ΎΚΑ"
        ],
        "tooltip-format": "{capacity}% ({power}W)"
    },
    "custom/power": {
        "format": "ΌτΤ",
        "tooltip": false,
        "on-click": "wlogout"
    }
}
